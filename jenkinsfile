pipeline {
  agent any 
  environment {
      IMAGE_NAME = "rajesh20032003/calc-jen"
      IMAGE_TAG = "${env.BUILD_NUMBER}"
      REGISTRY_CREDS = "dockerhub-creds"
  }

  stages {
    stage('checkout the scm') {
      steps {
        checkout scm 
        echo "checked out commit : ${env.GIT_COMMIT}"
      }
    }
    stage('build app') {
      steps {
        echo "no building its a static app"
        sh 'ls -la'
      }
    }
    stage('docker build -native') {
      steps {
        echo "docker building native way"
        sh """
        docker build \
        -t ${IMAGE_NAME}:${IMAGE_TAG} \
        . 
        """
      }
    }
  }
}